generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Campaign {
  id         String        @id @default(cuid())
  name       String
  adType     String
  upstream   String
  downstream String
  createdAt  DateTime      @default(now())
  records    DailyRecord[]
}

model DailyRecord {
  id          String   @id @default(cuid())
  campaignId  String
  date        DateTime
  impressions Int      @default(0)
  clicks      Int      @default(0)
  revenue     Decimal  @db.Decimal(12, 4)
  cost        Decimal  @db.Decimal(12, 4)
  cpm         Decimal? @db.Decimal(10, 4)
  cpa         Decimal? @db.Decimal(10, 4)
  cps         Decimal? @db.Decimal(10, 4)
  campaign    Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@index([campaignId, date])
  @@index([date])
}

model AnomalyLog {
  id         String   @id @default(cuid())
  recordId   String
  metric     String
  expected   Decimal  @db.Decimal(12, 4)
  actual     Decimal  @db.Decimal(12, 4)
  sigma      Decimal  @db.Decimal(10, 4)
  detectedAt DateTime @default(now())
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  role      String   @default("viewer")
  createdAt DateTime @default(now())
}
